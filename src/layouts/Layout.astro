---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Analytics from '../components/Analytics.astro';
import { site } from '../data/site';
import { withBase } from '../lib/url';

interface Props {
  title?: string;
  description?: string;
  /** Path-relative OG image; falls back to a generated default later. */
  ogImage?: string;
}

const {
  title,
  description = site.blurb,
  ogImage = '/og-default.png',
} = Astro.props;

const fullTitle = title
  ? `${title} · ${site.name}`
  : `${site.name} — ${site.tagline} in Central NJ`;

const canonical = new URL(Astro.url.pathname, Astro.site).href;

// Base-aware absolute URLs for public/ assets (works on apex + GH Pages subpath).
const faviconUrl = withBase('/favicon.png');
const ogImageAbs = new URL(withBase(ogImage), Astro.site).href;
const logoAbs = new URL(withBase('/favicon.png'), Astro.site).href;

// JSON-LD: local plumbing business. Helps Google show hours, phone, area.
// NOTE: intentionally NO aggregateRating — Google requires it be backed by
// real, on-page, verifiable review data; fabricating it risks a manual action.
// Add it only once the real Angi/Google rating + count are substantiated.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Plumber',
  name: site.name,
  description: site.blurb,
  telephone: site.phoneNumeric,
  url: new URL(withBase('/'), Astro.site).href,
  image: ogImageAbs,
  logo: logoAbs,
  priceRange: '$$',
  address: {
    '@type': 'PostalAddress',
    addressLocality: site.address.locality,
    addressRegion: site.address.state,
    addressCountry: 'US',
  },
  areaServed: {
    '@type': 'AdministrativeArea',
    name: site.address.region,
  },
  // Regular scheduled hours are Mon–Fri; emergency service is available
  // outside these hours but isn't modeled as standard opening hours.
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '08:00',
    closes: '17:00',
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href={faviconUrl} />
    <link rel="apple-touch-icon" href={faviconUrl} />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Fonts: Fraunces (display) + Inter (sans) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <script
      type="application/ld+json"
      set:html={JSON.stringify(jsonLd)}
    />

    <!-- If JS is disabled or fails, never leave reveal-on-scroll content hidden. -->
    <noscript>
      <style>
        .reveal {
          opacity: 1 !important;
          transform: none !important;
        }
      </style>
    </noscript>

    <Analytics />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      // Progressive reveal-on-scroll for .reveal elements.
      const els = document.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window && els.length) {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            });
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.1 }
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add('is-visible'));
      }
    </script>
  </body>
</html>
