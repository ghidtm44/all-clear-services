---
import Icon from './Icon.astro';
import { site } from '../data/site';
import { services } from '../data/services';

const accessKey = site.integrations.web3formsAccessKey;
const formReady = !!accessKey && accessKey !== 'YOUR_WEB3FORMS_ACCESS_KEY';
---

<section class="section request" id="request">
  <div class="container request__grid">
    <!-- Left: context & reassurance -->
    <div class="request__intro reveal">
      <p class="eyebrow">Request service</p>
      <h2>Tell us what’s going on — we’ll reach out to schedule.</h2>
      <p class="lead">
        Pick a day and time that work for you below. This sends your request
        straight to our office; a real person will call or email you back to
        confirm the appointment. For emergencies, please call
        <a href={site.phoneHref} class="request__phone-link">{site.phoneDisplay}</a>.
      </p>

      <ul class="request__points">
        <li><Icon name="check" size={18} /> No automated booking — we confirm every appointment personally</li>
        <li><Icon name="check" size={18} /> Free, no-obligation estimates</li>
        <li><Icon name="check" size={18} /> Emergency service available, including weekends &amp; holidays</li>
      </ul>

      <div class="request__callout">
        <Icon name="phone" size={22} />
        <div>
          <p class="request__callout-label">Prefer to talk now?</p>
          <a href={site.phoneHref} class="request__callout-phone">
            {site.phoneDisplay}
          </a>
        </div>
      </div>
    </div>

    <!-- Right: the form -->
    <div class="request__formwrap reveal">
      {
        !formReady && (
          <p class="request__notice">
            <strong>Setup note:</strong> add a Web3Forms access key to
            <code>src/data/site.ts</code> to enable live submissions. The form
            below is fully built and will work the moment a key is in place.
          </p>
        )
      }

      <form
        class="form"
        action="https://api.web3forms.com/submit"
        method="POST"
        data-request-form
      >
        <!-- Web3Forms config -->
        <input type="hidden" name="access_key" value={accessKey} />
        <input
          type="hidden"
          name="subject"
          value="New service request — All Clear Services website"
        />
        <input type="hidden" name="from_name" value="All Clear Services Website" />
        <!-- Honeypot anti-spam: bots fill this, humans don't -->
        <input
          type="checkbox"
          name="botcheck"
          class="visually-hidden"
          style="display:none"
          tabindex="-1"
          autocomplete="off"
        />
        <!-- Selected availability is mirrored here for the email -->
        <input type="hidden" name="preferred_appointment" data-availability-field />

        <div class="form__row">
          <div class="field">
            <label for="name">Full name <span aria-hidden="true">*</span></label>
            <input id="name" name="name" type="text" required autocomplete="name" />
          </div>
          <div class="field">
            <label for="phone">Phone <span aria-hidden="true">*</span></label>
            <input
              id="phone"
              name="phone"
              type="tel"
              required
              autocomplete="tel"
              inputmode="tel"
            />
          </div>
        </div>

        <div class="form__row">
          <div class="field">
            <label for="email">Email <span aria-hidden="true">*</span></label>
            <input id="email" name="email" type="email" required autocomplete="email" />
          </div>
          <div class="field">
            <label for="town">Town / city</label>
            <input id="town" name="town" type="text" autocomplete="address-level2" />
          </div>
        </div>

        <div class="form__row">
          <div class="field">
            <label for="service">Service needed <span aria-hidden="true">*</span></label>
            <select id="service" name="service" required>
              <option value="" disabled selected>Choose a service…</option>
              {services.map((s) => <option value={s.title}>{s.title}</option>)}
              <option value="Other">Something else</option>
            </select>
          </div>
          <div class="field">
            <label for="urgency">How urgent?</label>
            <select id="urgency" name="urgency">
              <option value="Standard — flexible">Standard — flexible</option>
              <option value="Soon — within a few days">Soon — within a few days</option>
              <option value="Emergency — call me ASAP">Emergency — call me ASAP</option>
            </select>
          </div>
        </div>

        <!-- Availability picker -->
        <fieldset class="availability">
          <legend>Preferred day &amp; time</legend>
          <p class="availability__help">
            Pick a date, then choose any times that work for you. We’ll confirm
            the exact appointment when we reach out — these are requests, not
            confirmed bookings.
          </p>

          <!-- Month calendar (single date) -->
          <p class="availability__sublabel">Preferred date</p>
          <div class="cal" data-cal>
            <div class="cal__head">
              <button type="button" class="cal__nav" data-cal-prev aria-label="Previous month">
                <Icon name="chevron" size={18} class="cal__nav-prev" />
              </button>
              <span class="cal__title" data-cal-title aria-live="polite"></span>
              <button type="button" class="cal__nav" data-cal-next aria-label="Next month">
                <Icon name="chevron" size={18} />
              </button>
            </div>
            <div class="cal__dow" aria-hidden="true">
              <span>Sun</span><span>Mon</span><span>Tue</span><span>Wed</span>
              <span>Thu</span><span>Fri</span><span>Sat</span>
            </div>
            <div class="cal__grid" data-cal-grid role="group" aria-label="Choose a preferred date"></div>
          </div>

          <!-- Time windows (multi-select) -->
          <p class="availability__sublabel">
            Preferred time of day
            <span class="availability__multi">— choose all that work</span>
          </p>
          <div class="availability__windows" data-windows role="group" aria-label="Preferred time windows">
            <button type="button" class="slot" data-window="Morning (8am–12pm)" aria-pressed="false">
              Morning<span>8am – 12pm</span>
            </button>
            <button type="button" class="slot" data-window="Afternoon (12pm–4pm)" aria-pressed="false">
              Afternoon<span>12pm – 4pm</span>
            </button>
          </div>
          <p class="availability__chosen" data-chosen aria-live="polite"></p>
        </fieldset>

        <div class="field">
          <label for="message">Describe the issue</label>
          <textarea
            id="message"
            name="message"
            rows="4"
            placeholder="e.g. Water heater is leaking from the base and there's no hot water…"
          ></textarea>
        </div>

        <button type="submit" class="btn btn--primary btn--lg form__submit">
          Send Service Request
        </button>
        <p class="form__fineprint">
          By submitting, you agree we may contact you about your request. We
          never share your information.
        </p>

        <p class="form__status" data-form-status role="status" aria-live="polite" hidden></p>
      </form>
    </div>
  </div>
</section>

<style>
  .request__grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: var(--sp-8);
    align-items: start;
  }
  .request__intro .lead {
    margin-top: var(--sp-4);
  }
  .request__phone-link {
    color: var(--copper-600);
    font-weight: 600;
    white-space: nowrap;
  }
  .request__points {
    list-style: none;
    padding: 0;
    margin: var(--sp-6) 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .request__points li {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: var(--fs-small);
    color: var(--ink-700);
  }
  .request__points :global(.icon) {
    color: var(--success-600);
    margin-top: 2px;
  }
  .request__callout {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    padding: var(--sp-5);
    background: var(--navy-050);
    border: 1px solid var(--navy-100);
    border-radius: var(--radius);
  }
  .request__callout :global(.icon) {
    color: var(--navy-700);
  }
  .request__callout-label {
    font-size: var(--fs-small);
    color: var(--ink-500);
  }
  .request__callout-phone {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--navy-900);
  }

  .request__formwrap {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: var(--sp-6);
    box-shadow: var(--shadow);
  }
  .request__notice {
    background: var(--copper-100);
    border: 1px solid #e9cbb6;
    border-radius: var(--radius);
    padding: var(--sp-4);
    font-size: var(--fs-small);
    color: var(--copper-700);
    margin-bottom: var(--sp-5);
  }
  .request__notice code {
    background: rgba(154, 75, 34, 0.12);
    padding: 0.1em 0.4em;
    border-radius: 4px;
    font-size: 0.85em;
  }

  /* Form primitives */
  .form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-4);
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: var(--sp-4);
  }
  .field label {
    font-size: var(--fs-small);
    font-weight: 600;
    color: var(--ink-900);
  }
  .field label span {
    color: var(--copper-600);
  }
  .field input,
  .field select,
  .field textarea {
    font-family: inherit;
    font-size: var(--fs-body);
    color: var(--ink-900);
    padding: 0.7rem 0.85rem;
    border: 1.5px solid var(--line);
    border-radius: var(--radius-sm);
    background: var(--paper);
    transition: border-color 0.15s var(--ease), box-shadow 0.15s var(--ease);
  }
  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--navy-600);
    box-shadow: 0 0 0 3px rgba(36, 74, 128, 0.12);
  }
  .field textarea {
    resize: vertical;
  }

  /* Availability */
  .availability {
    border: 1.5px solid var(--line);
    border-radius: var(--radius);
    padding: var(--sp-5);
    margin-bottom: var(--sp-4);
  }
  .availability legend {
    font-size: var(--fs-small);
    font-weight: 700;
    color: var(--ink-900);
    padding-inline: 0.5rem;
  }
  .availability__help {
    font-size: 0.85rem;
    color: var(--ink-500);
    margin-bottom: var(--sp-4);
  }
  .availability__sublabel {
    font-size: var(--fs-small);
    font-weight: 700;
    color: var(--ink-900);
    margin-bottom: var(--sp-3);
  }
  .availability__multi {
    font-weight: 400;
    color: var(--ink-500);
  }

  /* Month calendar */
  .cal {
    border: 1.5px solid var(--line);
    border-radius: var(--radius);
    padding: var(--sp-4);
    margin-bottom: var(--sp-5);
    background: var(--paper);
  }
  .cal__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--sp-3);
  }
  .cal__title {
    font-weight: 700;
    color: var(--ink-900);
    font-size: var(--fs-body);
  }
  .cal__nav {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border: 1.5px solid var(--line);
    border-radius: var(--radius-sm);
    background: var(--paper);
    color: var(--navy-700);
    cursor: pointer;
    transition: border-color 0.15s var(--ease), background 0.15s var(--ease),
      opacity 0.15s var(--ease);
  }
  .cal__nav:hover:not(:disabled) {
    border-color: var(--navy-600);
    background: var(--navy-050);
  }
  .cal__nav:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }
  .cal__nav-prev {
    transform: rotate(180deg);
  }
  .cal__dow {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 2px;
    margin-bottom: 4px;
  }
  .cal__dow span {
    text-align: center;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--ink-300);
    padding: 0.25rem 0;
  }
  .cal__grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 2px;
  }
  .cal__cell {
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: inherit;
    font-size: var(--fs-small);
    font-weight: 500;
    color: var(--ink-900);
    border: 1.5px solid transparent;
    border-radius: var(--radius-sm);
    background: none;
    cursor: pointer;
    transition: all 0.12s var(--ease);
  }
  .cal__cell--empty {
    cursor: default;
  }
  .cal__cell:not(:disabled):not(.cal__cell--empty):hover {
    border-color: var(--navy-600);
    background: var(--navy-050);
  }
  .cal__cell:disabled {
    color: var(--ink-300);
    opacity: 0.45;
    cursor: not-allowed;
  }
  .cal__cell--today {
    font-weight: 700;
    box-shadow: inset 0 0 0 1.5px var(--line);
  }
  .cal__cell[aria-pressed='true'] {
    background: var(--brand-blue);
    border-color: var(--brand-blue);
    color: var(--brand-yellow);
    font-weight: 700;
  }

  .availability__windows {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
  }
  .slot {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    padding: 0.65rem 0.5rem;
    border: 1.5px solid var(--line);
    border-radius: var(--radius-sm);
    background: var(--paper);
    cursor: pointer;
    font-family: inherit;
    font-weight: 600;
    font-size: var(--fs-small);
    color: var(--ink-900);
    transition: all 0.15s var(--ease);
  }
  .slot span {
    font-weight: 400;
    font-size: 0.78rem;
    color: var(--ink-500);
  }
  .slot:hover {
    border-color: var(--navy-600);
  }
  /* Multi-select: brand blue fill, yellow text, with a corner check. */
  .slot[aria-pressed='true'] {
    background: var(--brand-blue);
    border-color: var(--brand-blue);
    color: var(--brand-yellow);
  }
  .slot[aria-pressed='true'] span {
    color: rgba(244, 198, 0, 0.85);
  }
  .slot[aria-pressed='true']::after {
    content: '✓';
    position: absolute;
    top: 4px;
    right: 6px;
    font-size: 0.75rem;
    color: var(--brand-yellow);
  }
  .availability__chosen {
    margin-top: var(--sp-4);
    font-size: var(--fs-small);
    color: var(--navy-700);
    font-weight: 600;
    min-height: 1.2em;
  }

  .form__submit {
    width: 100%;
    margin-top: var(--sp-2);
  }
  .form__fineprint {
    font-size: 0.8rem;
    color: var(--ink-500);
    text-align: center;
    margin-top: var(--sp-3);
  }
  .form__status {
    margin-top: var(--sp-4);
    padding: var(--sp-4);
    border-radius: var(--radius-sm);
    font-size: var(--fs-small);
    text-align: center;
  }
  .form__status.is-success {
    background: #e7f4ed;
    color: var(--success-600);
    border: 1px solid #b9dcc7;
  }
  .form__status.is-error {
    background: #fdeaea;
    color: #b3261e;
    border: 1px solid #f3c4c1;
  }

  @media (max-width: 880px) {
    .request__grid {
      grid-template-columns: 1fr;
      gap: var(--sp-6);
    }
  }
  @media (max-width: 520px) {
    .form__row {
      grid-template-columns: 1fr;
      gap: 0;
    }
  }
</style>

<script>
  /**
   * Availability picker + form submission.
   *
   * A month-grid calendar lets the user pick ONE preferred date (past days and
   * Sundays disabled; navigation bounded to the current month forward). The
   * three time windows are MULTI-select — pick any combination. Both feed the
   * hidden `preferred_appointment` field that gets emailed.
   *
   * PHASE 2: fetch real free/busy from a serverless endpoint (Google Calendar
   * FreeBusy API) and disable fully-booked dates via `isBusy(iso)`. A static
   * site cannot read a private calendar directly — that needs a backend with a
   * service account or OAuth.
   *
   * Submission posts to Web3Forms via fetch for inline success without a page
   * redirect. No appointment is ever auto-booked: the payload is simply emailed
   * to the office for manual outreach.
   */
  const form = document.querySelector('[data-request-form]') as HTMLFormElement | null;
  const calWrap = form?.querySelector('[data-cal]') as HTMLElement | null;
  const calGrid = form?.querySelector('[data-cal-grid]') as HTMLElement | null;
  const calTitle = form?.querySelector('[data-cal-title]') as HTMLElement | null;
  const calPrev = form?.querySelector('[data-cal-prev]') as HTMLButtonElement | null;
  const calNext = form?.querySelector('[data-cal-next]') as HTMLButtonElement | null;
  const windowsWrap = form?.querySelector('[data-windows]') as HTMLElement | null;
  const chosenEl = form?.querySelector('[data-chosen]') as HTMLElement | null;
  const hiddenField = form?.querySelector('[data-availability-field]') as HTMLInputElement | null;
  const statusEl = form?.querySelector('[data-form-status]') as HTMLElement | null;

  // Bail cleanly if any required node is missing (e.g. after a future refactor)
  // rather than throwing and killing the whole picker silently.
  if (form && calGrid && calTitle && calPrev && calNext && windowsWrap && chosenEl && hiddenField && statusEl) {
    const DOW = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
    const MON = ['January', 'February', 'March', 'April', 'May', 'June', 'July',
      'August', 'September', 'October', 'November', 'December'];
    const MON_SHORT = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

    const today = new Date();
    today.setHours(0, 0, 0, 0);
    const todayISO = isoOf(today);

    let selectedDay = ''; // ISO yyyy-mm-dd
    let selectedDayLabel = '';
    const selectedWindows = new Set<string>();

    // Calendar is bounded: can't page earlier than the current month, and we
    // cap forward navigation at 12 months out (plenty for a service request).
    let viewYear = today.getFullYear();
    let viewMonth = today.getMonth(); // 0-indexed
    const minSerial = viewYear * 12 + viewMonth;
    const maxSerial = minSerial + 12;

    function isoOf(d: Date): string {
      // Local parts, not toISOString() (UTC would roll the date in the evening).
      return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(
        d.getDate()
      ).padStart(2, '0')}`;
    }

    // Hook for Phase 2 calendar availability — return true to disable a date.
    function isBusy(_iso: string): boolean {
      return false;
    }

    function renderCalendar() {
      calTitle!.textContent = `${MON[viewMonth]} ${viewYear}`;
      const serial = viewYear * 12 + viewMonth;
      calPrev!.disabled = serial <= minSerial;
      calNext!.disabled = serial >= maxSerial;

      calGrid!.innerHTML = '';
      const firstDow = new Date(viewYear, viewMonth, 1).getDay();
      const daysInMonth = new Date(viewYear, viewMonth + 1, 0).getDate();

      // Leading blanks so the 1st lands under the right weekday.
      for (let i = 0; i < firstDow; i++) {
        const blank = document.createElement('div');
        blank.className = 'cal__cell cal__cell--empty';
        calGrid!.appendChild(blank);
      }

      for (let day = 1; day <= daysInMonth; day++) {
        const d = new Date(viewYear, viewMonth, day);
        const iso = isoOf(d);
        const isPast = d < today;
        const isWeekend = d.getDay() === 0 || d.getDay() === 6; // closed Sat & Sun
        const disabled = isPast || isWeekend || isBusy(iso);

        const cell = document.createElement('button');
        cell.type = 'button';
        cell.className = 'cal__cell';
        cell.textContent = String(day);
        cell.dataset.date = iso;
        cell.dataset.label = `${DOW[d.getDay()]}, ${MON_SHORT[viewMonth]} ${day}, ${viewYear}`;
        if (iso === todayISO) cell.classList.add('cal__cell--today');
        if (disabled) {
          cell.disabled = true;
          cell.setAttribute('aria-disabled', 'true');
        } else {
          cell.setAttribute('aria-pressed', String(iso === selectedDay));
        }
        calGrid!.appendChild(cell);
      }
    }

    function sync() {
      const windows = [...selectedWindows];
      // Human-readable summary line under the picker.
      if (selectedDayLabel && windows.length) {
        chosenEl!.textContent = `Requested: ${selectedDayLabel} — ${windows.join(', ')}`;
      } else if (selectedDayLabel) {
        chosenEl!.textContent = `Requested: ${selectedDayLabel} — add a time of day`;
      } else if (windows.length) {
        chosenEl!.textContent = `Requested: ${windows.join(', ')} — pick a date`;
      } else {
        chosenEl!.textContent = '';
      }
      // Value emailed to the office.
      const datePart = selectedDayLabel
        ? `${selectedDayLabel} (${selectedDay})`
        : 'No date preference';
      const timePart = windows.length ? windows.join(', ') : 'No time preference';
      hiddenField!.value = `${datePart} — ${timePart}`;
    }

    // Date selection (event-delegated; survives month re-renders).
    calGrid.addEventListener('click', (e) => {
      const cell = (e.target as HTMLElement).closest('.cal__cell') as HTMLButtonElement | null;
      if (!cell || cell.disabled || cell.classList.contains('cal__cell--empty')) return;
      calGrid.querySelectorAll('.cal__cell[aria-pressed]').forEach((c) =>
        c.setAttribute('aria-pressed', 'false')
      );
      cell.setAttribute('aria-pressed', 'true');
      selectedDay = cell.dataset.date || '';
      selectedDayLabel = cell.dataset.label || '';
      sync();
    });

    calPrev.addEventListener('click', () => {
      if (viewMonth === 0) { viewMonth = 11; viewYear--; } else viewMonth--;
      renderCalendar();
    });
    calNext.addEventListener('click', () => {
      if (viewMonth === 11) { viewMonth = 0; viewYear++; } else viewMonth++;
      renderCalendar();
    });

    // Time windows — MULTI-select toggle.
    windowsWrap.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.slot') as HTMLButtonElement | null;
      if (!btn) return;
      const win = btn.dataset.window || '';
      const nowOn = btn.getAttribute('aria-pressed') !== 'true';
      btn.setAttribute('aria-pressed', String(nowOn));
      if (nowOn) selectedWindows.add(win);
      else selectedWindows.delete(win);
      sync();
    });

    renderCalendar();

    // Async submit with inline feedback.
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const submitBtn = form.querySelector('.form__submit') as HTMLButtonElement;
      const data = new FormData(form);

      // Guard: don't actually POST a placeholder key.
      const key = String(data.get('access_key') || '');
      if (!key || key === 'YOUR_WEB3FORMS_ACCESS_KEY') {
        showStatus(
          'This form isn’t connected yet. Add a Web3Forms access key to enable submissions.',
          false
        );
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending…';
      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: data,
        });
        const json = await res.json();
        if (json.success) {
          form.reset();
          // Reset the custom picker state too (form.reset doesn't touch it).
          selectedDay = '';
          selectedDayLabel = '';
          selectedWindows.clear();
          windowsWrap.querySelectorAll('.slot').forEach((b) =>
            b.setAttribute('aria-pressed', 'false')
          );
          renderCalendar();
          chosenEl.textContent = '';
          showStatus(
            'Thanks — your request is in. A member of our team will reach out shortly to confirm a time. For emergencies, please call us directly.',
            true
          );
        } else {
          throw new Error(json.message || 'Submission failed');
        }
      } catch (err) {
        showStatus(
          'Something went wrong sending your request. Please call us at the number above and we’ll take care of you.',
          false
        );
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send Service Request';
      }
    });

    function showStatus(msg: string, ok: boolean) {
      statusEl.textContent = msg;
      statusEl.hidden = false;
      statusEl.classList.toggle('is-success', ok);
      statusEl.classList.toggle('is-error', !ok);
      statusEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  }
</script>
