---
import { trustPoints } from '../data/services';
---

<section class="trustbar">
  <div class="container trustbar__inner">
    {
      trustPoints.map((t) => (
        <div class="trustbar__item">
          <span class="trustbar__stat">{t.stat}</span>
          <span class="trustbar__label">{t.label}</span>
        </div>
      ))
    }
  </div>
</section>

<style>
  .trustbar {
    background: var(--paper);
    border-bottom: 1px solid var(--line);
  }
  .trustbar__inner {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-5);
    padding-block: var(--sp-6);
  }
  .trustbar__item {
    text-align: center;
    border-left: 1px solid var(--line);
    padding-inline: var(--sp-4);
  }
  .trustbar__item:first-child {
    border-left: none;
  }
  .trustbar__stat {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 1.2rem + 1.4vw, 2.4rem);
    font-weight: 600;
    color: var(--navy-700);
    line-height: 1.1;
  }
  .trustbar__label {
    display: block;
    font-size: var(--fs-small);
    color: var(--ink-500);
    margin-top: 0.35rem;
  }

  @media (max-width: 680px) {
    .trustbar__inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--sp-5) var(--sp-3);
    }
    .trustbar__item:nth-child(odd) {
      border-left: none;
    }
  }
</style>
