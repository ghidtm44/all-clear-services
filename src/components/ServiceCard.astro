---
import Icon from './Icon.astro';
import type { Service } from '../data/services';
import { withBase } from '../lib/url';

interface Props {
  service: Service;
  /** When true, render the full item list (services page). */
  detailed?: boolean;
}
const { service, detailed = false } = Astro.props;
---

<article class="card reveal">
  <span class="card__icon">
    <Icon name={service.icon} size={26} />
  </span>
  <h3 class="card__title">{service.title}</h3>
  <p class="card__summary">{service.summary}</p>

  {
    detailed && (
      <ul class="card__items">
        {service.items.map((item) => (
          <li>
            <Icon name="check" size={16} />
            {item}
          </li>
        ))}
      </ul>
    )
  }

  <a href={withBase(`/services/${service.slug}/`)} class="card__link">
    {detailed ? `Explore ${service.title}` : 'Learn more'}
    <Icon name="chevron" size={16} />
  </a>
</article>

<style>
  .card {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: var(--sp-6);
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    transition: transform 0.2s var(--ease), box-shadow 0.2s var(--ease),
      border-color 0.2s var(--ease);
  }
  .card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow);
    border-color: transparent;
  }
  .card__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: var(--radius);
    background: var(--navy-050);
    color: var(--navy-700);
    margin-bottom: var(--sp-2);
  }
  .card:hover .card__icon {
    background: var(--copper-100);
    color: var(--copper-700);
  }
  .card__title {
    font-size: var(--fs-h3);
  }
  .card__summary {
    color: var(--ink-700);
    font-size: var(--fs-small);
    line-height: 1.6;
  }
  .card__items {
    list-style: none;
    padding: 0;
    margin-top: var(--sp-2);
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .card__items li {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    font-size: var(--fs-small);
    color: var(--ink-700);
  }
  .card__items :global(.icon) {
    color: var(--success-600);
    margin-top: 2px;
  }
  .card__link {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-weight: 600;
    font-size: var(--fs-small);
    color: var(--navy-700);
  }
  .card__link:hover {
    color: var(--copper-600);
  }
</style>
