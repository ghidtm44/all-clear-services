---
import Icon from './Icon.astro';
import { site } from '../data/site';
---

<section class="hero">
  <div class="hero__bg" aria-hidden="true"></div>
  <div class="container hero__inner">
    <div class="hero__content">
      <p class="eyebrow hero__eyebrow">Central New Jersey · Residential & Commercial</p>
      <h1 class="hero__title">
        Plumbing & HVAC<br />done clear, done right.
      </h1>
      <p class="lead hero__lead">
        From a dripping faucet to a flooded basement at 2 a.m., All Clear
        Services answers the call — with honest pricing, guaranteed
        workmanship, and one-hour emergency response, 24/7.
      </p>
      <div class="hero__actions">
        <a href="/contact/" class="btn btn--primary btn--lg">
          Request Service
        </a>
        <a href={site.phoneHref} class="btn btn--on-navy btn--lg">
          <Icon name="phone" size={18} /> {site.phoneDisplay}
        </a>
      </div>
      <ul class="hero__assurances">
        <li><Icon name="check" size={18} /> Free, no-obligation estimates</li>
        <li><Icon name="check" size={18} /> Flat per-job pricing — no hourly surprises</li>
        <li><Icon name="check" size={18} /> Nights, weekends & holidays</li>
      </ul>
    </div>

    <aside class="hero__card" aria-label="Why homeowners call All Clear">
      <div class="hero__card-rating">
        <span class="hero__stars" aria-hidden="true">
          <Icon name="star" size={20} /><Icon name="star" size={20} /><Icon
            name="star"
            size={20}
          /><Icon name="star" size={20} /><Icon name="star" size={20} />
        </span>
        <p class="hero__card-head">150+ five-star reviews</p>
        <p class="hero__card-sub">Multi-year Angi Super Service Award winner</p>
      </div>
      <blockquote class="hero__quote">
        “They showed up within the hour on a holiday weekend when our basement
        was flooding. Fast, professional, and they charged exactly what they
        quoted.”
        <cite>— Verified customer, Hamilton NJ</cite>
      </blockquote>
      <a href="/reviews/" class="hero__card-link">
        Read more reviews <Icon name="chevron" size={16} />
      </a>
    </aside>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background: var(--navy-900);
    color: #e3ebf6;
    overflow: hidden;
  }
  /* layered radial + linear wash, no stock image dependency */
  .hero__bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        60% 80% at 85% 10%,
        rgba(207, 116, 64, 0.22),
        transparent 60%
      ),
      radial-gradient(
        50% 60% at 0% 100%,
        rgba(36, 74, 128, 0.6),
        transparent 60%
      ),
      linear-gradient(160deg, var(--navy-900), var(--navy-800));
  }
  .hero__bg::after {
    /* faint blueprint grid */
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.035) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(80% 80% at 50% 30%, #000, transparent 80%);
  }
  .hero__inner {
    position: relative;
    display: grid;
    grid-template-columns: 1.3fr 0.9fr;
    gap: var(--sp-8);
    align-items: center;
    padding-block: clamp(3.5rem, 2rem + 8vw, 7rem);
  }
  .hero__eyebrow {
    color: var(--copper-500);
  }
  .hero__title {
    color: #fff;
    font-size: var(--fs-hero);
    margin-bottom: var(--sp-5);
  }
  .hero__lead {
    color: #c4d1e4;
    max-width: 52ch;
    margin-bottom: var(--sp-6);
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
    margin-bottom: var(--sp-6);
  }
  .hero__assurances {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .hero__assurances li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: var(--fs-small);
    color: #cdd9ea;
  }
  .hero__assurances :global(.icon) {
    color: var(--copper-500);
  }

  .hero__card {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: var(--radius-lg);
    padding: var(--sp-6);
    backdrop-filter: blur(8px);
    box-shadow: var(--shadow-lg);
  }
  .hero__stars {
    display: inline-flex;
    gap: 2px;
    color: var(--star);
  }
  .hero__card-head {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: #fff;
    margin-top: 0.5rem;
  }
  .hero__card-sub {
    font-size: var(--fs-small);
    color: #b6c4da;
  }
  .hero__quote {
    margin: var(--sp-5) 0;
    padding-top: var(--sp-5);
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    font-size: var(--fs-small);
    line-height: 1.6;
    color: #dbe5f2;
  }
  .hero__quote cite {
    display: block;
    margin-top: 0.6rem;
    font-style: normal;
    color: #95a6c0;
  }
  .hero__card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: var(--copper-500);
    font-weight: 600;
    font-size: var(--fs-small);
  }
  .hero__card-link:hover {
    color: var(--copper-100);
  }

  @media (max-width: 880px) {
    .hero__inner {
      grid-template-columns: 1fr;
      gap: var(--sp-6);
    }
    .hero__card {
      order: 2;
    }
  }
</style>
