---
import Icon from './Icon.astro';
import { site } from '../data/site';
import { withBase } from '../lib/url';
---

<section class="hero">
  <div class="hero__bg" aria-hidden="true"></div>
  <div class="container hero__inner">
    <div class="hero__content">
      <p class="eyebrow hero__eyebrow">Central New Jersey · Residential & Commercial</p>
      <h1 class="hero__title">
        Plumbing & HVAC<br />done clear, done right.
      </h1>
      <p class="lead hero__lead">
        From a dripping faucet to a flooded basement at 2 a.m., All Clear
        Services answers the call — with honest pricing, guaranteed
        workmanship, and one-hour emergency response.
      </p>
      <div class="hero__actions">
        <a href={withBase('/contact/')} class="btn btn--primary btn--lg">
          Request Service
        </a>
        <a href={site.phoneHref} class="btn btn--navy btn--lg">
          <Icon name="phone" size={18} /> {site.phoneDisplay}
        </a>
      </div>
      <ul class="hero__assurances">
        <li><Icon name="check" size={18} /> Free, no-obligation estimates</li>
        <li><Icon name="check" size={18} /> Flat per-job pricing — no hourly surprises</li>
        <li><Icon name="check" size={18} /> Nights, weekends & holidays</li>
      </ul>
    </div>

    <aside class="hero__card" aria-label="Why homeowners call All Clear">
      <div class="hero__card-rating">
        <span class="hero__stars" aria-hidden="true">
          <Icon name="star" size={20} /><Icon name="star" size={20} /><Icon
            name="star"
            size={20}
          /><Icon name="star" size={20} /><Icon name="star" size={20} />
        </span>
        <p class="hero__card-head">150+ five-star reviews</p>
        <p class="hero__card-sub">Multi-year Angi Super Service Award winner</p>
      </div>
      <blockquote class="hero__quote">
        “They showed up within the hour on a holiday weekend when our basement
        was flooding. Fast, professional, and they charged exactly what they
        quoted.”
        <cite>— Verified customer, Hamilton NJ</cite>
      </blockquote>
      <a href={withBase('/reviews/')} class="hero__card-link">
        Read more reviews <Icon name="chevron" size={16} />
      </a>
    </aside>
  </div>
</section>

<style>
  .hero {
    position: relative;
    /* Shares the header's surface so there is no color banding under the nav. */
    background: var(--surface);
    color: var(--ink-700);
    overflow: hidden;
  }
  /* Light blueprint wash — copper warmth top-right, navy cool bottom-left. */
  .hero__bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        55% 75% at 88% 0%,
        rgba(207, 116, 64, 0.12),
        transparent 60%
      ),
      radial-gradient(
        50% 70% at -5% 110%,
        rgba(36, 74, 128, 0.1),
        transparent 60%
      );
  }
  .hero__bg::after {
    /* faint blueprint grid in navy */
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(27, 58, 102, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(27, 58, 102, 0.05) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(85% 85% at 50% 25%, #000, transparent 85%);
  }
  .hero__inner {
    position: relative;
    display: grid;
    grid-template-columns: 1.3fr 0.9fr;
    gap: var(--sp-8);
    align-items: center;
    padding-block: clamp(3rem, 1.5rem + 7vw, 6rem);
  }
  .hero__title {
    color: var(--ink-900);
    font-size: var(--fs-hero);
    margin-bottom: var(--sp-5);
  }
  .hero__lead {
    color: var(--ink-700);
    max-width: 52ch;
    margin-bottom: var(--sp-6);
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
    margin-bottom: var(--sp-6);
  }
  .hero__assurances {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .hero__assurances li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: var(--fs-small);
    color: var(--ink-700);
  }
  .hero__assurances :global(.icon) {
    color: var(--copper-600);
  }

  .hero__card {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: var(--sp-6);
    box-shadow: var(--shadow-lg);
  }
  .hero__stars {
    display: inline-flex;
    gap: 2px;
    color: var(--star);
  }
  .hero__card-head {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--ink-900);
    margin-top: 0.5rem;
  }
  .hero__card-sub {
    font-size: var(--fs-small);
    color: var(--ink-500);
  }
  .hero__quote {
    margin: var(--sp-5) 0;
    padding-top: var(--sp-5);
    border-top: 1px solid var(--line);
    font-size: var(--fs-small);
    line-height: 1.6;
    color: var(--ink-900);
  }
  .hero__quote cite {
    display: block;
    margin-top: 0.6rem;
    font-style: normal;
    color: var(--ink-500);
  }
  .hero__card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: var(--copper-600);
    font-weight: 600;
    font-size: var(--fs-small);
  }
  .hero__card-link:hover {
    color: var(--copper-700);
  }

  @media (max-width: 880px) {
    .hero__inner {
      grid-template-columns: 1fr;
      gap: var(--sp-6);
    }
    .hero__card {
      order: 2;
    }
  }
</style>
