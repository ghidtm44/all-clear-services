---
/**
 * Brand lockup — the real All Clear Services mascot + wordmark logo.
 *
 * Two source variants (generated from the supplied artwork, see process-logo.mjs):
 *   - logo-lockup-dark.png  → navy wordmark, for LIGHT backgrounds (header)
 *   - logo-lockup-light.png → white wordmark, for DARK backgrounds (footer, drawer)
 *
 * Astro's <Image> optimizes/serves these as needed. `height` keeps the lockup
 * crisp; width is auto from the intrinsic aspect ratio.
 */
import { Image } from 'astro:assets';
import lockupDark from '../assets/logo-lockup-dark.png';
import lockupLight from '../assets/logo-lockup-light.png';
import { withBase } from '../lib/url';

interface Props {
  variant?: 'dark' | 'light';
  class?: string;
  height?: number;
}
const { variant = 'dark', class: className = '', height = 52 } = Astro.props;
// `variant` = desired wordmark color (matches call sites): 'light' → white
// wordmark for dark backgrounds (footer/drawer); 'dark' → navy wordmark for
// light backgrounds (header).
const src = variant === 'light' ? lockupLight : lockupDark;
---

<a href={withBase('/')} class={`logo ${className}`} aria-label="All Clear Services — home">
  <Image
    src={src}
    alt="All Clear Services"
    height={height}
    densities={[1.5, 2]}
    loading="eager"
    class="logo__img"
  />
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
  }
  .logo__img {
    width: auto;
    height: 52px;
    display: block;
  }
  @media (max-width: 560px) {
    .logo__img {
      height: 44px;
    }
  }
</style>
