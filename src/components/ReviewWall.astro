---
import Icon from './Icon.astro';
import { reviews, reviewSummary } from '../data/reviews';

interface Props {
  /** Limit how many cards to show (homepage shows a few; reviews page all). */
  limit?: number;
  heading?: string;
}
const { limit, heading = 'Trusted by neighbors across central New Jersey' } =
  Astro.props;
const shown = limit ? reviews.slice(0, limit) : reviews;
---

<section class="section section--warm" id="reviews">
  <div class="container">
    <div class="reviews__head reveal">
      <div>
        <p class="eyebrow">Reviews</p>
        <h2>{heading}</h2>
      </div>
      <div class="reviews__summary">
        <span class="reviews__stars" aria-hidden="true">
          {Array.from({ length: 5 }).map(() => <Icon name="star" size={20} />)}
        </span>
        <p class="reviews__summary-text">
          <strong>{reviewSummary.countLabel} five-star reviews</strong>
          <span>on {reviewSummary.platform}</span>
        </p>
      </div>
    </div>

    <div class="reviews__grid">
      {
        shown.map((r) => (
          <figure class="review reveal">
            <span class="review__stars" aria-label={`${r.rating} out of 5 stars`}>
              {Array.from({ length: r.rating }).map(() => (
                <Icon name="star" size={16} />
              ))}
            </span>
            <blockquote class="review__quote">{r.quote}</blockquote>
            <figcaption class="review__cite">
              <span class="review__name">{r.name}</span>
              {r.location && <span class="review__loc">{r.location}</span>}
              <span class="review__source">{r.source}</span>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>

<style>
  .reviews__head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--sp-5);
    margin-bottom: var(--sp-7);
    flex-wrap: wrap;
  }
  .reviews__summary {
    text-align: right;
  }
  .reviews__stars {
    display: inline-flex;
    gap: 2px;
    color: var(--star);
  }
  .reviews__summary-text {
    margin-top: 0.25rem;
  }
  .reviews__summary-text strong {
    display: block;
    color: var(--ink-900);
    font-size: 1.1rem;
  }
  .reviews__summary-text span {
    font-size: var(--fs-small);
    color: var(--ink-500);
  }

  .reviews__grid {
    columns: 3;
    column-gap: var(--sp-5);
  }
  .review {
    break-inside: avoid;
    margin: 0 0 var(--sp-5);
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: var(--sp-5);
    box-shadow: var(--shadow-sm);
  }
  .review__stars {
    display: inline-flex;
    gap: 2px;
    color: var(--star);
    margin-bottom: var(--sp-3);
  }
  .review__quote {
    font-size: var(--fs-small);
    line-height: 1.65;
    color: var(--ink-900);
  }
  .review__cite {
    margin-top: var(--sp-4);
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .review__name {
    font-weight: 600;
    color: var(--ink-900);
    font-size: var(--fs-small);
  }
  .review__loc {
    font-size: var(--fs-small);
    color: var(--ink-500);
  }
  .review__source {
    font-size: 0.8rem;
    color: var(--copper-700);
    font-weight: 600;
    margin-top: 0.25rem;
  }

  @media (max-width: 900px) {
    .reviews__grid {
      columns: 2;
    }
  }
  @media (max-width: 600px) {
    .reviews__grid {
      columns: 1;
    }
    .reviews__summary {
      text-align: left;
    }
  }
</style>
