---
interface Props {
  eyebrow?: string;
  title: string;
  text?: string;
}
const { eyebrow, title, text } = Astro.props;
---

<section class="pagehead">
  <div class="pagehead__bg" aria-hidden="true"></div>
  <div class="container pagehead__inner">
    {eyebrow && <p class="eyebrow pagehead__eyebrow">{eyebrow}</p>}
    <h1 class="pagehead__title">{title}</h1>
    {text && <p class="lead pagehead__text">{text}</p>}
  </div>
</section>

<style>
  .pagehead {
    position: relative;
    /* Shares the header/hero surface — seamless under the nav, no banding. */
    background: var(--surface);
    color: var(--ink-700);
    overflow: hidden;
    border-bottom: 1px solid var(--line);
  }
  .pagehead__bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(50% 70% at 92% 0%, rgba(207, 116, 64, 0.1), transparent 60%);
  }
  .pagehead__bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(27, 58, 102, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(27, 58, 102, 0.05) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(85% 90% at 30% 0%, #000, transparent 80%);
  }
  .pagehead__inner {
    position: relative;
    padding-block: clamp(3rem, 2rem + 5vw, 5rem);
    max-width: 64ch;
  }
  .pagehead__title {
    color: var(--ink-900);
    font-size: var(--fs-h1);
  }
  .pagehead__text {
    color: var(--ink-700);
    margin-top: var(--sp-4);
  }
</style>
