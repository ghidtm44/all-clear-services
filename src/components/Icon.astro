---
/**
 * Line-art icon set. Stroked, currentColor, no fill — deliberately understated
 * to read as professional rather than clip-art. Add new icons by key.
 */
interface Props {
  name: string;
  size?: number;
  class?: string;
}
const { name, size = 28, class: className = '' } = Astro.props;

const paths: Record<string, string> = {
  // Plumbing — pipe with joint
  pipe: '<path d="M4 8h7a3 3 0 0 1 3 3v9"/><path d="M14 8h6"/><path d="M17 5v6"/><rect x="2" y="5" width="4" height="6" rx="1"/>',
  // Drain — grate / flow
  drain: '<path d="M3 6h18"/><path d="M3 6l1.4 12.2a2 2 0 0 0 2 1.8h11.2a2 2 0 0 0 2-1.8L21 6"/><path d="M9 10v6"/><path d="M15 10v6"/><path d="M12 10v6"/>',
  // Heating/cooling — thermostat
  thermostat: '<path d="M14 14.76V5a2 2 0 1 0-4 0v9.76a4 4 0 1 0 4 0Z"/><path d="M12 9v6"/>',
  // Hot water — tank with droplet
  'water-heater': '<rect x="6" y="3" width="12" height="18" rx="3"/><path d="M12 7c1.6 1.8 2.4 3.1 2.4 4.2A2.4 2.4 0 0 1 12 13.6a2.4 2.4 0 0 1-2.4-2.4C9.6 10.1 10.4 8.8 12 7Z"/><path d="M9 21v-1"/><path d="M15 21v-1"/>',
  // Camera/excavation — inspection scope
  camera: '<circle cx="12" cy="12" r="3.2"/><path d="M5 8h2.5l1.2-1.6h6.6L16.5 8H19a2 2 0 0 1 2 2v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2Z"/>',
  // Emergency — clock
  clock: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3.5 2"/>',
  // UI — phone
  phone: '<path d="M5 4h4l2 5-2.5 1.5a11 11 0 0 0 5 5L15 13l5 2v4a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2Z"/>',
  // UI — calendar
  calendar: '<rect x="3" y="5" width="18" height="16" rx="2"/><path d="M3 9h18"/><path d="M8 3v4"/><path d="M16 3v4"/>',
  // UI — check
  check: '<path d="M20 6 9 17l-5-5"/>',
  // UI — chevron right
  chevron: '<path d="M9 6l6 6-6 6"/>',
  // UI — map pin
  pin: '<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>',
  // UI — shield (licensed/insured)
  shield: '<path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6Z"/><path d="m9 12 2 2 4-4"/>',
  // UI — chat / language
  globe: '<circle cx="12" cy="12" r="9"/><path d="M3 12h18"/><path d="M12 3a14 14 0 0 1 0 18 14 14 0 0 1 0-18Z"/>',
  // UI — star (filled, for ratings)
  star: '<path d="M12 3.5l2.6 5.3 5.9.86-4.25 4.14 1 5.87L12 17.9l-5.25 2.77 1-5.87L3.5 9.66l5.9-.86Z"/>',
  // UI — mail
  mail: '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="m4 7 8 6 8-6"/>',
  // UI — menu
  menu: '<path d="M4 7h16"/><path d="M4 12h16"/><path d="M4 17h16"/>',
  // UI — close
  close: '<path d="M6 6l12 12"/><path d="M18 6 6 18"/>',
  // UI — wrench (general repair)
  wrench: '<path d="M14.5 6.5a3.5 3.5 0 0 0-4.6 4.2L4 16.6 7.4 20l5.9-5.9a3.5 3.5 0 0 0 4.2-4.6l-2.3 2.3-2.1-.6-.6-2.1Z"/>',
  // Social — Instagram
  instagram: '<rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1"/>',
};

const isFilled = name === 'star';
const body = paths[name] ?? paths.wrench;
---

<svg
  class={`icon ${className}`}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill={isFilled ? 'currentColor' : 'none'}
  stroke={isFilled ? 'none' : 'currentColor'}
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
  set:html={body}
/>

<style>
  .icon {
    flex-shrink: 0;
  }
</style>
