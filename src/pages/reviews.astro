---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import HousecallReviews from '../components/HousecallReviews.astro';
import CTABand from '../components/CTABand.astro';
import { site } from '../data/site';

const embed = site.integrations.googleReviewsEmbedHtml;
---

<Layout
  title="Reviews"
  description="Read why central New Jersey homeowners and businesses trust All Clear Services — 150+ verified five-star reviews on Housecall Pro."
>
  <PageHeader
    eyebrow="Reviews"
    title="Don’t take our word for it"
    text="We’ve earned 150+ five-star reviews on Housecall Pro by showing up, doing honest work, and standing behind it."
  />

  <HousecallReviews heading="What our customers say" />

  {
    /*
      Optional secondary reviews slot. The Housecall Pro widget above is the
      primary source; if a Google-reviews widget (Trustindex / Elfsight) is
      ever added, set site.integrations.googleReviewsEmbedHtml and it renders
      here. Left empty by default.
      NOTE: that value is injected via set:html — operator-trusted HTML only.
    */
  }
  {
    embed && (
      <section class="section section--warm">
        <div class="container">
          <div class="section-head section-head--center">
            <p class="eyebrow">Live from Google</p>
            <h2>Our latest Google reviews</h2>
          </div>
          <div class="greviews" set:html={embed} />
        </div>
      </section>
    )
  }

  <CTABand
    title="Ready to join them?"
    text="Experience the service our customers rave about. Call for a free estimate today."
  />
</Layout>
