---
import Layout from '../layouts/Layout.astro';
import { site } from '../data/site';
import Icon from '../components/Icon.astro';
import { withBase } from '../lib/url';
---

<Layout title="Page not found">
  <section class="section nf">
    <div class="container nf__inner">
      <p class="eyebrow">404</p>
      <h1>We couldn’t find that page</h1>
      <p class="lead">
        The page may have moved. Let’s get you back on track — or just give us a
        call and we’ll help directly.
      </p>
      <div class="nf__actions">
        <a href={withBase('/')} class="btn btn--primary btn--lg">Back to home</a>
        <a href={site.phoneHref} class="btn btn--ghost btn--lg">
          <Icon name="phone" size={18} /> {site.phoneDisplay}
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .nf__inner {
    text-align: center;
    max-width: 56ch;
    margin-inline: auto;
  }
  .nf__actions {
    display: flex;
    gap: var(--sp-4);
    justify-content: center;
    margin-top: var(--sp-6);
    flex-wrap: wrap;
  }
</style>
