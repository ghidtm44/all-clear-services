---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import CTABand from '../components/CTABand.astro';
import Icon from '../components/Icon.astro';
import { serviceAreas, serviceAreaIntro } from '../data/service-areas';
---

<Layout
  title="Service Areas"
  description="All Clear Services covers Mercer County and central New Jersey — Trenton, Princeton, Hamilton, Lawrenceville, Ewing, West Windsor, and dozens more towns."
>
  <PageHeader
    eyebrow="Where we work"
    title="Serving Mercer County & central New Jersey"
    text={serviceAreaIntro}
  />

  <section class="section">
    <div class="container">
      <ul class="areas reveal">
        {
          serviceAreas.map((town) => (
            <li class="areas__item">
              <Icon name="pin" size={18} />
              {town}
            </li>
          ))
        }
      </ul>

      <p class="areas__note reveal">
        Don’t see your town? We likely still cover you — give us a call at
        <a href="tel:+18004052505">800-405-2505</a> to check.
      </p>
    </div>
  </section>

  <CTABand
    title="Serving your neighborhood today"
    text="Local technicians, fast response, and free estimates across central New Jersey."
  />
</Layout>

<style>
  .areas {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
  }
  .areas__item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1rem;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    font-size: var(--fs-small);
    font-weight: 500;
    color: var(--ink-900);
    transition: border-color 0.15s var(--ease), background 0.15s var(--ease);
  }
  .areas__item:hover {
    border-color: var(--navy-600);
    background: var(--navy-050);
  }
  .areas__item :global(.icon) {
    color: var(--copper-600);
  }
  .areas__note {
    margin-top: var(--sp-7);
    text-align: center;
    color: var(--ink-500);
  }
  .areas__note a {
    color: var(--copper-600);
    font-weight: 600;
  }

  @media (max-width: 860px) {
    .areas {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 600px) {
    .areas {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 400px) {
    .areas {
      grid-template-columns: 1fr;
    }
  }
</style>
